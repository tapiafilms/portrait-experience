{
  "buildCommand": "vite build",
  "outputDirectory": "dist",
  "rewrites": [
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ],
  "functions": {
    "api/**/*.js": {
      "maxDuration": 60
    },
    "api/transform/[sessionId].js": {
      "maxDuration": 60,
      "includeFiles": "public/**"
    }
  }
}
